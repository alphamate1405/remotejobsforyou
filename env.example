# ── Telegram ──────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN

# Your channel's ID (numbers, e.g. -1001234567890)
# Or the username like @myjobschannel
TELEGRAM_CHANNEL_ID=@your_channel

# ── Dodo Payments ─────────────────────────────────────────
# From Dodo dashboard → API Keys
DODO_API_KEY=YOUR_DODO_API_KEY

# From Dodo dashboard → Products → your subscription product
DODO_PRODUCT_ID=YOUR_DODO_PRODUCT_ID

# From Dodo dashboard → Webhooks → signing secret
DODO_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ── Server ────────────────────────────────────────────────
# Port your webhook server listens on
WEBHOOK_PORT=8080
